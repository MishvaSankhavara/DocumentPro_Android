        <activity
            android:name="com.artifex.sonui.ChoosePathActivity"
            android:configChanges="keyboard|keyboardHidden|orientation|screenLayout|screenSize|smallestScreenSize"
            android:exported="true"
            android:theme="@style/ActivityDialog"
            android:windowSoftInputMode="stateHidden" />
        <activity
            android:name="com.docpro.scanner.settings.LocaleSelectionActivity"
            android:exported="false"
            android:theme="@style/ListFileTheme" />
        <activity
            android:name=".ui.activities.SelectDocumentActivity"
            android:exported="false"
            android:theme="@style/ListFileTheme" />
        <activity
            android:name=".ui.activities.DocumentListActivity"
            android:exported="false"
            android:theme="@style/ListFileTheme" />
        <activity
            android:name=".ui.activities.SearchDocumentActivity"
            android:exported="false"
            android:theme="@style/SearchTheme" />
        <activity
            android:name=".ui.activities.SplashScreenActivity"
            android:exported="true"
            android:theme="@style/MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".photopick.ui.MatisseActivity"
            android:theme="@style/ActivityChoosePhoto" />
        <activity
            android:name=".photopick.internal.ui.SelectedPreviewActivity"
            android:theme="@style/ActivityChoosePhoto" />
        <activity
