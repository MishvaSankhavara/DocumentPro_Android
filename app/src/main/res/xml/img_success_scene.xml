<?xml version="1.0" encoding="utf-8"?>
<MotionScene xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <Transition
        app:constraintSetEnd="@+id/end"
        app:constraintSetStart="@+id/start"
        app:duration="700">
        <KeyFrameSet>
            <KeyPosition
                app:framePosition="50"
                app:keyPositionType="deltaRelative"
                app:motionTarget="@+id/bodyBg"
                app:percentHeight="1"
                app:percentY="1" />
            <KeyAttribute
                android:alpha="1"
                app:framePosition="50"
                app:motionTarget="@+id/bodyBg" />
            <KeyPosition
                app:framePosition="65"
                app:keyPositionType="deltaRelative"
                app:motionTarget="@+id/fileLayout"
                app:percentY="1" />
            <KeyAttribute
                android:alpha="1"
                app:framePosition="65"
                app:motionTarget="@+id/fileLayout" />
            <KeyPosition
                app:framePosition="90"
                app:keyPositionType="deltaRelative"
                app:motionTarget="@+id/optLayout"
                app:percentY="1" />
            <KeyAttribute
                android:alpha="1"
                app:framePosition="90"
                app:motionTarget="@+id/optLayout" />
            <KeyAttribute
                android:alpha="0"
                app:framePosition="80"
                app:motionTarget="@+id/topLayout" />


        </KeyFrameSet>
    </Transition>
    <ConstraintSet android:id="@+id/start">
        <Constraint android:id="@+id/operateCloseImg" />
        <Constraint android:id="@+id/guidelineTop" />
        <Constraint android:id="@+id/guidelineCenter" />
        <Constraint android:id="@+id/backImg" />
        <Constraint android:id="@+id/topLayout">
            <PropertySet android:alpha="0" />
        </Constraint>
        <Constraint
            android:id="@+id/bodyBg"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:alpha="0"
            android:background="@drawable/ip_bg_convert_success_message"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/guidelineCenter" />
        <Constraint
            android:id="@+id/fileLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:alpha="0"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/guidelineCenter" />
        <Constraint
            android:id="@+id/optLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:alpha="0"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/fileLayout" />
    </ConstraintSet>
    <ConstraintSet android:id="@+id/end">
        <Constraint android:id="@+id/operateCloseImg" />
        <Constraint android:id="@+id/guidelineTop" />
        <Constraint android:id="@+id/guidelineCenter" />
        <Constraint android:id="@+id/backImg" />
        <Constraint android:id="@+id/topLayout">
            <PropertySet android:alpha="1" />
        </Constraint>
        <Constraint
            android:id="@+id/bodyBg"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:alpha="1"
            android:background="@drawable/ip_bg_convert_success_message"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/guidelineTop" />
        <Constraint
            android:id="@+id/fileLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:alpha="1"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/guidelineTop"
            app:layout_constraintVertical_chainStyle="packed" />
        <Constraint
            android:id="@+id/optLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:alpha="1"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/fileLayout" />
    </ConstraintSet>
</MotionScene>
