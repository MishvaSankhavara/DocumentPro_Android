<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/text_annotation_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:padding="12dp">

    <EditText
        android:id="@+id/annotation_edit_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_text_annotation"
        android:gravity="center"
        android:hint="Type here..."
        android:minHeight="40dp"
        android:minWidth="100dp"
        android:padding="8dp"
        android:textColor="@color/black"
        android:textSize="16sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/btn_cancel"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@drawable/ic_close_new1"
        app:layout_constraintBottom_toTopOf="@id/annotation_edit_text"
        app:layout_constraintEnd_toStartOf="@id/annotation_edit_text"
        app:layout_constraintStart_toStartOf="@id/annotation_edit_text"
        app:layout_constraintTop_toTopOf="@id/annotation_edit_text" />

    <ImageView
        android:id="@+id/btn_flip"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@drawable/ic_flip_black_text"
        app:layout_constraintBottom_toTopOf="@id/annotation_edit_text"
        app:layout_constraintEnd_toEndOf="@id/annotation_edit_text"
        app:layout_constraintStart_toEndOf="@id/annotation_edit_text"
        app:layout_constraintTop_toTopOf="@id/annotation_edit_text" />

    <ImageView
        android:id="@+id/btn_resize"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@drawable/ic_resize"
        app:layout_constraintBottom_toBottomOf="@id/annotation_edit_text"
        app:layout_constraintEnd_toEndOf="@id/annotation_edit_text"
        app:layout_constraintStart_toEndOf="@id/annotation_edit_text"
        app:layout_constraintTop_toBottomOf="@id/annotation_edit_text" />
</androidx.constraintlayout.widget.ConstraintLayout>
