<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/bottomEditToolBar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="bottom|center_vertical|center_horizontal|center"
    android:background="@color/bg_tittle">

    <LinearLayout
        android:id="@+id/ll_pdf_edit_bottom_toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/shape_bg_pdf_edit_toolbar"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/pdf_bottom_draw"
            android:layout_width="match_parent"
            android:layout_height="102dp"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/rl_paint_xp"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/sizeTitleTv"
                    style="@style/FontMedium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="22dp"
                    android:gravity="center"
                    android:text="@string/info_size"
                    android:textColor="@color/app_white"
                    android:textSize="14sp" />

                <com.example.documenpro.ui.customviews.seekbar.RangeSeekBar
                    android:id="@+id/thickness_seekBar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    app:rsb_gravity="center"
                    app:rsb_max="50"
                    app:rsb_min="0.25"
                    app:rsb_mode="single" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/sizeTv"
                    style="@style/FontMedium"
                    android:layout_width="55dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:gravity="center"
                    android:textColor="@color/app_white"
                    android:textSize="14sp" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerColor"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:orientation="horizontal"
                android:overScrollMode="never"
                android:paddingEnd="20dp"
                android:scrollbars="none"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_color" />
        </LinearLayout>

<!--        <View-->
<!--            android:id="@+id/v_ll_ink_bottom_line"-->
<!--            android:layout_width="match_parent"-->
<!--            android:layout_height="@dimen/dp_1"-->
<!--            android:background="#f2f4f9" />-->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal">

            <com.example.documenpro.ui.customviews.EditBtn
                android:id="@+id/btnHighlight"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                app:ImageEdt="@drawable/ic_preview_highlight" />

            <com.example.documenpro.ui.customviews.EditBtn
                android:id="@+id/btnDrawNew"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                app:ImageEdt="@drawable/ic_preview_draw" />

            <com.example.documenpro.ui.customviews.EditBtn
                android:id="@+id/btnDelete"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                app:ImageEdt="@drawable/ic_eraser" />
        </LinearLayout>
    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>