<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="match_parent"
    android:background="@drawable/editor_sheet_tab"
    android:orientation="horizontal">

    <LinearLayout
        android:id="@+id/sheetTab"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="horizontal">

        <com.artifex.sonui.editor.SOTextView
            android:id="@+id/button1"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_gravity="center_horizontal"
            android:background="@color/editor_transparent"
            android:clickable="false"
            android:fontFamily="@font/roboto_medium"
            android:gravity="center"
            android:paddingHorizontal="16dp"
            android:textColor="@color/bottom_sheet_text_ss"
            android:textSize="14sp" />

        <android.supportv1.v4.widget.Space
            android:id="@+id/spacer"
            android:layout_width="4dp"
            android:layout_height="match_parent" />

        <ImageView
            android:id="@+id/button2"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginEnd="8dp"
            android:background="@color/editor_transparent"
            android:clickable="true"
            android:focusable="true"
            android:padding="4dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_close"
            app:tint="@color/bottom_sheet_text_ss" />
    </LinearLayout>
</merge>