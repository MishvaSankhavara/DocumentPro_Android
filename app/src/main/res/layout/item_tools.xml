<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="12dp"
    android:layout_marginEnd="5dp"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:paddingHorizontal="5dp">

    <View
        android:id="@+id/v_tools_bg"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:background="@drawable/bg_tools_item"

        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_max="65dp" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_tools_icon"
        android:layout_width="50dp"
        android:layout_height="50dp"
        app:layout_constraintBottom_toBottomOf="@id/v_tools_bg"
        app:layout_constraintEnd_toEndOf="@id/v_tools_bg"
        app:layout_constraintStart_toStartOf="@id/v_tools_bg"
        app:layout_constraintTop_toTopOf="@id/v_tools_bg"
        app:srcCompat="@drawable/ic_tools_unlock" />

    <TextView
        android:id="@+id/tvTools"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="1dp"
        android:fontFamily="@font/bold"
        android:gravity="center"
        android:maxLines="2"
        android:paddingTop="6dp"
        android:text="asfsdf"
        android:textColor="@color/colorTextPrimary"
        android:textSize="11sp"
        app:layout_constraintEnd_toEndOf="@id/v_tools_bg"

        app:layout_constraintStart_toStartOf="@id/v_tools_bg"
        app:layout_constraintTop_toBottomOf="@id/v_tools_bg" />

</androidx.constraintlayout.widget.ConstraintLayout>
