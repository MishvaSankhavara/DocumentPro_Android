<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background">

    <com.example.documenpro.ui.customviews.smartrefresh.SmartRefreshLayout
        android:id="@+id/smartRefreshLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srlHeaderMaxDragRate="3.5"
        app:srlHeaderTriggerRate="2">

        <androidx.coordinatorlayout.widget.CoordinatorLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/app_background">

            <com.google.android.material.appbar.AppBarLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/app_background">

                <com.google.android.material.appbar.CollapsingToolbarLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:contentScrim="#00000000"
                    app:layout_scrollFlags="scroll|exitUntilCollapsed">

                    <LinearLayout
                        android:id="@+id/ll_header_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="16dp"
                        android:paddingTop="20dp"
                        android:paddingBottom="16dp"
                        app:layout_collapseMode="parallax">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/roboto_regular"
                            android:text="@string/welcome_back"
                            android:textColor="@color/colorTextSecondary"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tv_greeting"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/roboto_bold"
                            android:text="@string/app_name"
                            android:textColor="@color/app_primary_text"
                            android:textSize="22sp" />

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:id="@+id/cv_search_bar"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginTop="20dp"
                            android:background="@drawable/bg_search_bar"
                            android:paddingHorizontal="12dp">

                            <ImageView
                                android:id="@+id/iv_search_icon"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_search"
                                android:tint="@color/colorTextSecondary"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:fontFamily="@font/roboto_regular"
                                android:text="@string/search_documents"
                                android:textColor="@color/colorTextSecondary"
                                android:textSize="14sp"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toEndOf="@id/iv_search_icon"
                                app:layout_constraintTop_toTopOf="parent" />
                        </androidx.constraintlayout.widget.ConstraintLayout>

                        <LinearLayout
                            android:id="@+id/ll_document_type"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="24dp"
                            android:background="@color/app_background"
                            android:orientation="horizontal"
                            android:weightSum="5">

                            <com.example.documenpro.ui.customviews.DocumentTypeItemView
                                android:id="@+id/btnPdf"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                app:backgroundColorFileType="@color/tint_pdf"
                                app:imgFileType="@drawable/ic_type_pdf"
                                app:nameFileType="@string/document_pdf"
                                app:cornerRadiusFileType="16dp"/>

                            <com.example.documenpro.ui.customviews.DocumentTypeItemView
                                android:id="@+id/btnWord"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                app:backgroundColorFileType="@color/tint_word"
                                app:imgFileType="@drawable/ic_type_word"
                                app:nameFileType="@string/document_word"
                                app:cornerRadiusFileType="16dp"/>

                            <com.example.documenpro.ui.customviews.DocumentTypeItemView
                                android:id="@+id/btnExcel"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                app:backgroundColorFileType="@color/tint_excel"
                                app:imgFileType="@drawable/ic_type_excel"
                                app:nameFileType="@string/document_excel"
                                app:cornerRadiusFileType="16dp"/>

                            <com.example.documenpro.ui.customviews.DocumentTypeItemView
                                android:id="@+id/btnPpt"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                app:backgroundColorFileType="@color/tint_ppt"
                                app:imgFileType="@drawable/ic_type_ppt"
                                app:nameFileType="@string/document_ppt"
                                app:cornerRadiusFileType="16dp"/>

                            <com.example.documenpro.ui.customviews.DocumentTypeItemView
                                android:id="@+id/btnTXT"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                app:backgroundColorFileType="@color/tint_txt"
                                app:imgFileType="@drawable/ic_type_txt"
                                app:nameFileType="@string/txt"
                                app:cornerRadiusFileType="16dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.appbar.CollapsingToolbarLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:background="@color/colorPrimaryDim"
                        android:visibility="gone" />

                    <include
                        layout="@layout/ad_native_container_banner1"
                        android:visibility="gone" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:background="@color/colorPrimaryDim" />

                    <include
                        layout="@layout/layout_scroll_tab_home"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/colorPrimaryDim" />
                </LinearLayout>

            </com.google.android.material.appbar.AppBarLayout>

            <androidx.core.widget.NestedScrollView
                android:id="@+id/nestedScrollView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                app:layout_behavior="@string/appbar_scrolling_view_behavior">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <androidx.viewpager.widget.ViewPager
                        android:id="@+id/vp_content"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <LinearLayout
                        android:id="@+id/llPermission_container"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@color/app_background"
                        android:gravity="center"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <include
                            layout="@layout/layout_permission_denied"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="90dp" />
                    </LinearLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.core.widget.NestedScrollView>

        </androidx.coordinatorlayout.widget.CoordinatorLayout>

    </com.example.documenpro.ui.customviews.smartrefresh.SmartRefreshLayout>
</androidx.constraintlayout.widget.ConstraintLayout>