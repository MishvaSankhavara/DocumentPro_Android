<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_tittle"
    android:animateLayoutChanges="true"
    android:fitsSystemWindows="true">

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/shadow_bottom"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_marginBottom="50dp"
        android:scaleType="fitXY"
        app:layout_constraintBottom_toBottomOf="@id/bottom_container"
        app:layout_constraintStart_toStartOf="parent"
        app:srcCompat="@drawable/bg_home_tab" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/bg_tittle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <include layout="@layout/toolbar_main" />

        <include layout="@layout/toolbar_search" />

        <include layout="@layout/toolbar_edit" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/page_and_list_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.0"
        android:baselineAligned="false"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@id/bottom_container"
        app:layout_constraintTop_toBottomOf="@id/header">

        <RelativeLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="85">

            <RelativeLayout
                android:id="@id/doc_inner_container"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipChildren="false">

                <LinearLayout
                    android:id="@id/doc_cover"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/editor_transparent"
                    android:orientation="vertical"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@id/doc_note_editor"
                    android:layout_width="@dimen/sodk_editor_note_editor_width"
                    android:layout_height="wrap_content"
                    android:background="@color/editor_pdf_note_color"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <com.artifex.sonui.editor.SOTextView
                        android:id="@id/doc_note_editor_author"
                        style="@style/sodk_editor_note_editor_textview_style"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="@dimen/_15sdp"
                        android:textStyle="bold" />

                    <com.artifex.sonui.editor.SOTextView
                        android:id="@id/doc_note_editor_date"
                        style="@style/sodk_editor_note_editor_textview_style"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/_13sdp" />

                    <com.artifex.sonui.editor.SOEditText
                        android:id="@id/doc_note_editor_text"
                        style="@style/sodk_editor_note_editor_textview_style"
                        android:layout_height="wrap_content"
                        android:gravity="top"
                        android:imeOptions="flagNoFullscreen"
                        android:minLines="6"
                        android:text="" />
                </LinearLayout>

                <com.artifex.sonui.editor.PDFFormTextEditor
                    android:id="@+id/pdf_form_text_editor_layout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clipChildren="false"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <com.artifex.sonui.editor.SOEditText
                        android:id="@+id/pdf_text_editor"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@color/editor_transparent"
                        android:cursorVisible="false"
                        android:focusableInTouchMode="true"
                        android:gravity="top"
                        android:imeOptions="flagNoFullscreen"
                        android:text=""
                        android:textColor="@color/editor_transparent"
                        android:textColorHighlight="@color/editor_transparent_01" />

                    <com.artifex.sonui.editor.SelectionHandle
                        android:id="@+id/pdf_form_text_editor_handle_upper"
                        android:layout_width="@dimen/_30sdp"
                        android:layout_height="@dimen/_30sdp"
                        android:tag="1"
                        android:visibility="gone" />

                    <com.artifex.sonui.editor.SelectionHandle
                        android:id="@+id/pdf_form_text_editor_handle_lower"
                        android:layout_width="@dimen/_30sdp"
                        android:layout_height="@dimen/_30sdp"
                        android:tag="2"
                        android:visibility="gone" />
                </com.artifex.sonui.editor.PDFFormTextEditor>

                <com.artifex.sonui.editor.PDFFormCheckboxEditor
                    android:id="@+id/pdf_form_checkbox_editor_layout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <com.artifex.sonui.editor.SOEditText
                        android:id="@+id/pdf_checkbox_editor"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@color/editor_transparent"
                        android:cursorVisible="false"
                        android:focusableInTouchMode="true"
                        android:gravity="top"
                        android:imeOptions="flagNoFullscreen"
                        android:text=""
                        android:textColor="@color/editor_transparent"
                        android:textColorHighlight="@color/editor_transparent_01" />
                </com.artifex.sonui.editor.PDFFormCheckboxEditor>
            </RelativeLayout>


            <TextView
                android:id="@id/footer_page_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_alignParentTop="true"
                android:layout_marginStart="13dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/shape_bg_page_num"
                android:gravity="center"
                android:paddingStart="12dp"
                android:paddingTop="6dp"
                android:paddingEnd="12dp"
                android:paddingBottom="7dp"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:visibility="visible" />

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/btn_full_screen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:layout_marginStart="13dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/shape_bg_page_num"
                android:paddingStart="2dp"
                android:paddingTop="2dp"
                android:paddingEnd="2dp"
                android:paddingBottom="2dp"
                android:src="@drawable/baseline_fullscreen_24"
                android:tint="@color/app_white" />

            <LinearLayout
                android:id="@+id/doUndoLayout"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:layout_alignParentEnd="true"
                android:layout_alignParentBottom="true"
                android:layout_marginEnd="13dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/shape_bg_pdf_edit_draw_back"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="visible">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/img_undo"

                    android:layout_width="39dp"
                    android:layout_height="34dp"
                    android:paddingStart="9dp"
                    android:paddingTop="5dp"
                    android:paddingEnd="6dp"
                    android:paddingBottom="5dp"
                    app:srcCompat="@drawable/ic_draw_back" />

                <!--                    <View-->
                <!--                        android:id="@+id/v_undo_line"-->
                <!--                        android:layout_width="@dimen/dp_1"-->
                <!--                        android:layout_height="16dp"-->
                <!--                        android:background="#4dffffff" />-->

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/img_redo"
                    android:layout_width="39dp"
                    android:layout_height="34dp"
                    android:paddingStart="6dp"
                    android:paddingTop="5dp"
                    android:paddingEnd="9dp"
                    android:paddingBottom="5dp"
                    app:srcCompat="@drawable/ic_draw_go" />
            </LinearLayout>


            <include
                layout="@layout/layout_search_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_alignParentBottom="true"
                android:layout_marginEnd="13dp"
                android:layout_marginBottom="14dp"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent" />

            <FrameLayout
                android:id="@+id/paint_size_container"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentBottom="true"
                android:layout_centerHorizontal="true"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="13dp"
                android:background="@drawable/shape_bg_pdf_edit_paint_size"
                android:visibility="gone">

                <View
                    android:id="@+id/paint_size"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_paint_2" />
            </FrameLayout>
        </RelativeLayout>

        <RelativeLayout
            android:id="@id/pages_container"
            android:layout_width="0.0dip"
            android:layout_height="match_parent"
            android:layout_weight="15"
            android:background="@color/editor_pdf_pages_bg"
            android:orientation="vertical"
            android:paddingLeft="@dimen/_5sdp"
            android:paddingRight="@dimen/_5sdp"
            android:visibility="gone" />
    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottom_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toTopOf="@id/ll_ad"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <include
            layout="@layout/document_view_pdf_bottom"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:visibility="visible"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <include
            layout="@layout/document_view_pdf_bottom_edit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>


    <LinearLayout
        android:id="@+id/ll_ad"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent">

        <include layout="@layout/ad_native_container_banner_2" />

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>