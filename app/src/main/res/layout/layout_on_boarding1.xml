<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.appcompat.widget.AppCompatImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/bg1" />


    <View
        android:id="@+id/guide_view"
        android:layout_width="1dp"
        android:layout_height="match_parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@drawable/new_guide_card_gradient_bg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="@+id/title_tv" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/title_tv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:fontFamily="@font/roboto_bold"
        android:paddingHorizontal="18dp"
        android:paddingLeft="18dp"
        android:paddingRight="18dp"
        android:text="@string/onboarding_title_organize_pdf"
        android:textColor="@color/app_white"
        android:textSize="32sp"
        app:layout_constraintBottom_toTopOf="@+id/subtitle_tv"
        app:layout_constraintStart_toStartOf="@+id/subtitle_tv" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/subtitle_tv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="56dp"
        android:fontFamily="@font/roboto_medium"
        android:includeFontPadding="false"
        android:paddingHorizontal="18dp"
        android:paddingLeft="18dp"
        android:paddingRight="18dp"
        android:text="@string/onboarding_description_file_management"
        android:textColor="@color/app_white"
        android:textSize="16sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>
