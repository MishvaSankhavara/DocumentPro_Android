<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorAccent">@color/colorAccent</item>
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="android:windowLightStatusBar">true</item>


        <!-- Customize your theme here. -->
    </style>
    <style name="TextViewFont_PopSemiBold">
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>
    <style name="AppThemeTranslucentStatusBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
    </style>
    <style name="SearchTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowLightStatusBar">false</item>
        <item name="bottomSheetDialogTheme">@style/AppBottomSheetDialogTheme</item>
    </style>
    <style name="MainActivity" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:homeAsUpIndicator">@drawable/ic_sidebar</item>
    </style>
    <style name="SplashTheme" parent="MainActivity">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
    <style name="FontSemiBold">
        <item name="android:includeFontPadding">false</item>
        <item name="android:fontFamily">@font/roboto_bold</item>
    </style>
    <style name="TextToolbar">
        <item name="android:includeFontPadding">false</item>
        <item name="android:fontFamily">@font/roboto_semibold</item>
        <item name="android:textSize">17sp</item>
    </style>
    <style name="ListFileTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorAccent">@color/colorAccent</item>
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="bottomSheetDialogTheme">@style/AppBottomSheetDialogTheme</item>
        <item name="android:homeAsUpIndicator">@drawable/ic_return_white</item>
    </style>

    <style name="TextButtonDialog">
        <item name="fontFamily">@font/roboto_bold</item>
        <item name="android:textSize">14sp</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/app_text_light</item>
        <item name="android:layout_marginEnd">24dp</item>
        <item name="android:layout_marginTop">24dp</item>
        <item name="android:layout_marginBottom">24dp</item>
    </style>

    <style name="NewShareDialogStyle_text">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/app_editor_tab_line</item>
        <item name="android:paddingBottom">16dp</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="NewShareDialogStyle_item">
        <item name="android:gravity">left|center_horizontal|clip_horizontal</item>
        <item name="android:orientation">vertical</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="NewShareDialogStyle_icon">
        <item name="android:background">@drawable/share_action_new_bg</item>
        <item name="android:layout_width">50dp</item>
        <item name="android:layout_height">50dp</item>
        <item name="android:layout_margin">10dp</item>
        <item name="android:scaleType">centerInside</item>
    </style>

    <style name="NewShareDialogStyle_vertical">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
    </style>

    <style name="MyEditTextStyle">
        <item name="android:textColorHighlight">#401c73e1</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:textCursorDrawable">@drawable/shape_cursor</item>
        <item name="android:fontFamily">@font/roboto_medium</item>
    </style>

    <style name="AppBottomSheetDialogTheme" parent="Theme.Design.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/AppModalStyle</item>
    </style>

    <style name="AppModalStyle" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background"></item>
    </style>

    <style name="Test" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowLightStatusBar">false</item>
        <item name="bottomSheetDialogTheme">@style/AppBottomSheetDialogTheme</item>

    </style>

    <style name="ListFile" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:homeAsUpIndicator">@drawable/ic_return</item>
        <item name="bottomSheetDialogTheme">@style/AppBottomSheetDialogTheme</item>

    </style>

    <style name="sodk_editor_note_editor_textview_style">
        <item name="android:textColor">@color/editor_palette_black</item>
        <item name="android:background">@color/editor_transparent</item>
        <item name="android:layout_width">@dimen/sodk_editor_note_editor_width</item>
    </style>

    <style name="FontBold">
        <item name="android:fontFamily">@font/roboto_bold</item>
    </style>

    <style name="FontRegular">
        <item name="android:fontFamily">@font/roboto_regular</item>
    </style>

    <style name="FontMedium">
        <item name="android:fontFamily">@font/roboto_medium</item>
    </style>

    <style name="TextTitle15">
        <item name="android:textSize">15sp</item>
        <item name="android:ellipsize">end</item>
        <item name="android:gravity">clip_horizontal</item>
        <item name="maxLines">1</item>
    </style>

    <style name="Text13">
        <item name="android:textSize">13sp</item>
        <item name="android:ellipsize">end</item>
        <item name="android:gravity">clip_horizontal</item>
        <item name="maxLines">1</item>
    </style>
    <style name="CustomBottomSheetDialogTheme">
        <item name="bottomSheetStyle">@style/CustomBottomSheetStyle</item>
    </style>

    <style name="CustomBottomSheetStyle">
        <item name="android:background">@android:color/transparent</item>
    </style>

    <style name="sodk_editor_font_color_button" parent="@android:style/Widget.Button">
        <item name="android:layout_width">17.0pt</item>
        <item name="android:layout_height">17.0pt</item>
        <item name="android:layout_margin">@dimen/_5sdp</item>
    </style>

    <style name="sodk_editor_dialog_title_style">
        <item name="android:textSize">12.0pt</item>
        <item name="android:textColor">@color/editor_picker_text_color</item>
        <item name="android:background">@color/editor_picker_bg_color</item>
    </style>

    <style name="sodk_editor_wheel_title_style">
        <item name="android:textSize">18.0sp</item>
        <item name="android:textColor">@color/editor_palette_white</item>
        <item name="android:paddingTop">@dimen/_5sdp</item>
    </style>

    <style name="sodk_cert_detail_title">
        <item name="android:textSize">@dimen/_13sdp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">10.0sp</item>
    </style>

    <style name="sodk_cert_detail_heading" parent="@style/sodk_cert_detail_title">
        <item name="android:layout_marginTop">10.0sp</item>
    </style>

    <style name="sodk_cert_detail_description" parent="@style/sodk_cert_detail_subheading">
        <item name="android:textSize">12.0sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:layout_marginBottom">@dimen/_5sdp</item>
        <item name="android:layout_marginStart">30.0sp</item>
    </style>

    <style name="sodk_dialog_panel_border" parent="@style/sodk_dialog_panel">
        <item name="android:background">@drawable/dialog_border</item>
    </style>

    <style name="sodk_dialog_button">
        <item name="android:textColor">@color/explorer_blue</item>
        <item name="android:background">@color/palette_white</item>
        <item name="android:color">@color/explorer_blue</item>
    </style>


    <style name="style_slide_show" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:statusBarColor">@color/black</item>
        <item name="android:fontFamily">@font/roboto_bold</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="sodk_editor_pdf_toc_text_box_style">
        <item name="android:textColor">@color/editor_palette_black</item>
        <item name="android:background">@color/editor_palette_white</item>
    </style>
    <style name="ActivityDialog" parent="Theme.AppCompat.Light.Dialog">
        <item name="windowNoTitle">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>
    <style name="ActivityFullScreen" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowFullscreen">true</item>
    </style>
    <style name="ActivityDialog2" parent="ThemeOverlay.AppCompat.Dialog">
        <item name="android:windowIsTranslucent">false</item>
    </style>
    <style name="sodk_editor_shape_dialog_title_style">
        <item name="android:textSize">12.0pt</item>
        <item name="android:textColor">@color/editor_shape_picker_text_color</item>
        <item name="android:background">@color/editor_shape_picker_bg_color</item>
    </style>

    <style name="sodk_editor_page_menu_style">
        <item name="android:background">@drawable/editor_page_menu</item>
        <item name="android:padding">@dimen/_5sdp</item>
    </style>

    <style name="sodk_editor_page_menu_divider_style">
        <item name="android:background">@color/editor_palette_black</item>
        <item name="android:padding">@dimen/_5sdp</item>
    </style>

    <style name="sodk_editor_page_menu_item_style">
        <item name="android:textSize">24.0sp</item>
        <item name="android:background">@color/editor_palette_white</item>
        <item name="android:padding">@dimen/_5sdp</item>
    </style>

    <style name="sodk_editor_wheel_plus_style">
        <item name="android:textSize">32.0sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/editor_palette_green_1</item>
        <item name="android:paddingRight">@dimen/_7sdp</item>
    </style>

    <style name="sodk_editor_wheel_checkbox_label_style">
        <item name="android:textSize">18.0sp</item>
        <item name="android:textColor">@color/editor_palette_white</item>
        <item name="android:paddingLeft">@dimen/_7sdp</item>
    </style>

    <style name="sodk_editor_font_formula_text_box_style">
        <item name="android:textColor">@color/editor_palette_white</item>
        <item name="android:background">@color/editor_palette_slate_grey</item>
    </style>

    <style name="sodk_editor_wheel_checkbox_style" parent="@style/Theme.AppCompat.Light">
        <item name="colorControlActivated">@color/editor_palette_ltgrey</item>
        <item name="colorControlNormal">@color/editor_palette_ltgrey</item>
    </style>

    <style name="sodk_cert_detail_subheading" parent="@style/sodk_cert_detail_heading">
        <item name="android:textSize">14.0sp</item>
        <item name="android:layout_marginStart">24.0dip</item>
    </style>

    <style name="sodk_editor_alert_edit_text_style" />

    <style name="sodk_dialog_panel">
        <item name="android:padding">@dimen/_7sdp</item>
        <item name="android:layout_margin">@dimen/_10sdp</item>
    </style>

    <style name="sodk_dialog_separator">
        <item name="android:background">@color/explorer_blue</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/_1sdp</item>
        <item name="android:layout_marginTop">@dimen/_7sdp</item>
        <item name="android:layout_marginBottom">@dimen/_7sdp</item>
        <item name="android:layout_alignParentTop">true</item>
    </style>
    <style name="sodk_editor_alert_dialog_style" parent="@style/Theme.AppCompat.Light.Dialog.Alert">
        <item name="android:buttonStyle">@style/sodk_editor_alert_button_style</item>
        <item name="android:textColor">@color/editor_palette_black</item>
    </style>
    <style name="sodk_editor_alert_button_style">
        <item name="android:textSize">14.0sp</item>
        <item name="android:textColor">@color/app_sodk_editor_alert_button_color</item>
        <item name="android:textAllCaps">true</item>
    </style>



    <style name="ActivityCommon" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorAccent">@color/colorAccent</item>
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="bottomSheetDialogTheme">@style/AppBottomSheetDialogTheme</item>
        <item name="android:homeAsUpIndicator">@drawable/ic_return</item>
    </style>
