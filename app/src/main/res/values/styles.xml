    <style name="TitleCollapseAppBar">
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/colorSolidText</item>
        <item name="fontFamily">@font/roboto_semibold</item>
    </style>
    <style name="Popup.Dracula" parent="Widget.AppCompat.ListPopupWindow">
        <item name="android:popupBackground">@color/app_album_popup_background</item>
    </style>
    <style name="ActivityChoosePhoto" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowLightStatusBar">true</item>
    </style>
    <style name="SoundProgressBarVertical">
        <item name="android:focusable">false</item>
        <item name="android:maxWidth">6dp</item>
        <item name="android:indeterminateOnly">false</item>
        <item name="android:indeterminateDrawable">@drawable/sound_progress</item>
        <item name="android:progressDrawable">@drawable/sound_progress</item>
        <item name="android:minWidth">6dp</item>
        <item name="android:thumb">@null</item>
    </style>

    <style name="Text13Bold">
        <item name="android:textSize">13sp</item>
        <item name="android:ellipsize">end</item>
        <item name="fontFamily">@font/roboto_medium</item>

        <item name="android:gravity">clip_horizontal</item>
        <item name="maxLines">1</item>
    </style>

    <style name="Text15Bold">
