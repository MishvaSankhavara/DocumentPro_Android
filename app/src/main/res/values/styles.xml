        <item name="album.emptyView">@drawable/ic_pdf_empty</item>
        <item name="album.emptyView.textColor">@color/app_album_empty_view</item>
        <item name="item.placeholder">@color/app_item_placeholder</item>
        <item name="item.checkCircle.backgroundColor">
            @color/app_item_check_circle_background
        </item>
        <item name="item.checkCircle.borderColor">@color/dracula_item_checkCircle_borderColor</item>
        <item name="page.bg">@color/app_page_background_dark</item>
